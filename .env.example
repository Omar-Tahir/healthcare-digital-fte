# ─── LLM Provider (ADR-014) ───────────────────────────────────────────────────
# Which LLM provider to use: "groq" (free dev), "gemini" (free tier), "anthropic" (production)
LLM_PROVIDER=groq

# Groq — RECOMMENDED for development (free, no billing, 30 req/min)
# Get key at https://console.groq.com (email signup only, no credit card)
GROQ_API_KEY=gsk_your_key_here

# Gemini free tier — only works if GCP project has NO billing account linked
# Get key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (production)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override default model for active provider
# Groq default:     llama-3.3-70b-versatile
# Gemini default:   gemini-2.0-flash
# Anthropic default: claude-sonnet-4-6
# LLM_MODEL=llama-3.3-70b-versatile

# ─── FHIR / Epic integration ──────────────────────────────────────────────────
# Sandbox non-production client ID (from Epic App Orchard — appId=54049)
FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
FHIR_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
FHIR_CLIENT_ID=dc8570f4-6a5e-4960-b875-d37b98ce26a3
FHIR_PRIVATE_KEY_PATH=keys/private_key.pem
FHIR_KID=healthcare-fte-2026-04-27
# Public JWK Set URL registered in Epic (GitHub raw — no server needed for sandbox):
FHIR_JWKS_URL=https://raw.githubusercontent.com/Omar-Tahir/healthcare-digital-fte/main/src/api/static/jwks.json

# ─── MIMIC-IV benchmark ───────────────────────────────────────────────────────
# BENCHMARK_DELAY_S=1.0
